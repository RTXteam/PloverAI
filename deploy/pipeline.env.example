# /var/lib/ploverai/app/pipeline/.env — read by the FastAPI systemd
# unit on service start. chmod 600, owned by the `ploverai` service
# user. NEVER commit a populated copy of this file.
#
# OPENROUTER_API_KEY — from https://openrouter.ai/keys. set a
# monthly spend cap in the OpenRouter dashboard alongside this.
OPENROUTER_API_KEY=sk-or-v1-replace-me

# PLOVERAI_API_KEY — the shared key the frontend sends as X-API-Key.
# defense in depth behind nginx basic auth. generate with:
#   openssl rand -hex 32
# the SAME value must go into frontend/.env.local as NEXT_PUBLIC_API_KEY
# BEFORE you `npm run build`, since it's baked into the JS bundle.
PLOVERAI_API_KEY=replace-with-32-byte-hex

# optional: PLOVERAI_CORS_ORIGINS — comma-separated list of origins
# allowed to call /api/*. blank disables CORS entirely. unset in
# production since nginx serves UI + API at the same origin.
# PLOVERAI_CORS_ORIGINS=
