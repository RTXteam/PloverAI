# /var/lib/ploverai/app/frontend/.env.local — read by Next.js at
# BUILD TIME. you must `npm run build` again after editing this file
# for the new values to take effect. these vars get baked into the
# static JS bundle.

# in production both UI and API live behind the same nginx vhost,
# so the browser resolves /api/v1/* against the page origin. leave
# this empty.
NEXT_PUBLIC_API_BASE=

# must EXACTLY match PLOVERAI_API_KEY in pipeline/.env. "public" in
# that any browser using the UI sees it in devtools — keep nginx
# basic auth + OpenRouter spend cap as the real protection layers.
NEXT_PUBLIC_API_KEY=replace-with-same-value-as-PLOVERAI_API_KEY
