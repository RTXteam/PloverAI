# PloverAI nginx vhost — copy to /etc/nginx/sites-available/ploverai,
# replace the two __PLACEHOLDERS__, then symlink into sites-enabled.
# certbot will edit this file in place to add the TLS block + the
# 80→443 redirect once you run `certbot --nginx -d __DOMAIN__`.
#
# placeholders:
#   __DOMAIN__   — the domain you pointed at this EC2 (e.g. ploverai.example.com)
#   __APP_DIR__  — where the cloned repo lives (e.g. /var/lib/ploverai/app)

# rate limit zone: 10 requests/min per client IP for /api/* endpoints.
# big enough that a normal labmate using the UI never hits it; small
# enough that a script can't burn through your OpenRouter budget in
# minutes. burst=20 + nodelay lets short bursts (e.g. clicking through
# 5 historical runs) through immediately while still capping sustained
# traffic.
limit_req_zone $binary_remote_addr zone=ploverai_api:10m rate=10r/m;

server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__;

    # certbot will edit this server block to add the 80→443 redirect.
    # before that runs, this block also serves the ACME http-01
    # challenge from /.well-known/acme-challenge/ automatically.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name __DOMAIN__;

    # TLS — populated by certbot. uncomment / leave for certbot to fill:
    # ssl_certificate     /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;
    # include             /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # basic auth — single shared credential for the whole site.
    # blocks crawlers, scripted bots, and curl one-liners before they
    # ever reach the FastAPI service or the static frontend. rotate
    # with `htpasswd /etc/nginx/.auth/ploverai <user>`.
    auth_basic           "PloverAI";
    auth_basic_user_file /etc/nginx/.auth/ploverai;

    # security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options           "SAMEORIGIN"                          always;
    add_header X-Content-Type-Options    "nosniff"                             always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin"     always;

    # body size cap — TRAPI queries are JSON, never large. 1 MB is
    # comfortable headroom; anything bigger is probably an attack
    # payload.
    client_max_body_size 1m;

    # /api/v1/* — proxy to the FastAPI service on localhost:8000.
    # SSE streaming endpoint needs proxy_buffering off + a long read
    # timeout so the live log stream isn't buffered or cut off.
    location /api/ {
        limit_req zone=ploverai_api burst=20 nodelay;

        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # SSE / streaming support
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # everything else — static export from Next.js build.
    # rsync'd into /var/www/ploverai/out/ during deploy.
    location / {
        root  /var/www/ploverai/out;
        try_files $uri $uri/ $uri.html /index.html;

        # cache static assets aggressively. Next.js fingerprints
        # filenames so a far-future cache is safe.
        location /_next/static/ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }

        # never cache the HTML shell — that's the entry point for the
        # whole client-side app + the place we read ?run=<id> from.
        location = /index.html {
            expires -1;
            add_header Cache-Control "no-store, no-cache, must-revalidate";
        }
    }

    # static export emits trailingSlash URLs (next.config.ts:
    # trailingSlash: true) — make sure non-trailing requests get
    # redirected so deep-linked routes resolve.
    if ($request_uri ~* "^[^?]*[^/])$") {
        return 301 $scheme://$host$1/$is_args$args;
    }
}
