# dev defaults: FastAPI runs on localhost:8000 alongside `npm run dev`
# on localhost:3000. in production both UI and API are behind one
# nginx vhost on the EC2, so NEXT_PUBLIC_API_BASE should be the empty
# string (same-origin) and CORS becomes a non-issue.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# the same value PLOVERAI_API_KEY is set to on the Python side. this
# is "public" in the sense that any browser using the deployed UI
# ends up seeing it in devtools — keep server-side rate limiting and
# an OpenRouter spend cap as the real safety net.
NEXT_PUBLIC_API_KEY=dev-key-change-me
